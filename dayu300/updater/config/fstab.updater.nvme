#SATA hard disk and USB disk config
/dev/block/nvme0n1p2               /usr     ext4     ro,barrier=1  wait
/dev/block/nvme0n1p3               /vendor     ext4     ro,barrier=1  wait
/dev/block/nvme0n1p4               /data       ext4     nosuid,nodev,noatime,barrier=1,data=ordered,noauto_da_alloc wait,reservedsize=104857600
/dev/block/nvme0n1p5               /misc       none     none  wait
/dev/block/nvme0n1p6               /sdcard     ext4     rw  wait